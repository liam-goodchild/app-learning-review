APP_HOST=0.0.0.0
APP_PORT=8080
DATABASE_URL=sqlite:////data/learning.db
VAULT_PATH=/vault
VAULT_IMPORT_FOLDERS=00 - Inbox,02 - Notes
APP_SECRET_KEY=change-me-use-a-long-random-string
APP_USERNAME=admin
APP_PASSWORD=change-me
SECURE_COOKIES=false
SCAN_INTERVAL_SECONDS=300
MIN_FILE_AGE_SECONDS=20
REVIEW_SESSION_SIZE=12
ENABLE_PERIODIC_SCAN=true

# Required for host-side Codex generation worker endpoints. Use a long random value.
WORKER_TOKEN=change-me-worker-token
APP_BASE_URL=http://127.0.0.1:8080
